# ==========================================
# VoiceFlow AI Production Environment Settings
# ==========================================

# Core Application
API_V1_STR=/api/v1
PROJECT_NAME="VoiceFlow AI Production"

# Security (CRITICAL: Change these to secure values!)
# Use `openssl rand -hex 32` to generate secure strings
SECRET_KEY=9b18fe839bba372cc836f1e59658e5f2ebf9e1e5a10889ba267bb5cedb61b15
ENCRYPTION_KEY=5e8fbc18c0c1b79f8fa266e7b235ee2a  # Must be exactly 32 hex chars / bytes
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS Allowed Origins (Comma-separated list of domains)
BACKEND_CORS_ORIGINS=https://app.voiceflow.ai,https://api.voiceflow.ai,http://52.190.193.17:3001,http://52.190.193.17:3000,http://localhost:3001,http://localhost:3000

# PostgreSQL Production Config
POSTGRES_SERVER=postgres
POSTGRES_USER=voiceflow_db_user
POSTGRES_PASSWORD=generate_some_secure_random_db_password_here_!
POSTGRES_DB=voiceflow_prod

# Redis URL for Celery Worker & Websockets Broker
REDIS_HOST=redis
REDIS_PORT=6379

# LiveKit SFU (Production Cloud/Self-Hosted Setup)
LIVEKIT_URL=https://livekit.voiceflow.ai
LIVEKIT_API_KEY=devkey-replace-with-livekit-production-key
LIVEKIT_API_SECRET=lk_api_secret_32_characters_long_for_security

# Default Administrator Seed Credentials
FIRST_SUPERUSER_EMAIL=admin@voiceflow.ai
FIRST_SUPERUSER_PASSWORD=Admin123!
